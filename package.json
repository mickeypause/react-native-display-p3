{
  "name": "react-native-p3-monorepo",
  "private": true,
  "description": "Monorepo for react-native-p3 and its example app",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "build": "bun run --filter react-native-p3 build",
    "typecheck": "bun run --filter react-native-p3 typecheck",
    "typecheck:example": "bun run --filter react-native-p3-example typecheck",
    "clean": "bun run --filter react-native-p3 clean",
    "lint": "oxlint packages/react-native-p3/src apps/example --react-plugin",
    "test": "bun run --filter react-native-p3 test",
    "expo-module": "bun run --filter react-native-p3 expo-module"
  },
  "devDependencies": {
    "oxlint": "^1.63.0",
    "typescript": "~5.9.2"
  }
}
